APP_ENV=development
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080
BASE_PATH=
APP_BIND_IP=127.0.0.1
APP_PORT=8080
ADMIN_TOKEN=replace-with-a-long-random-token
APP_MASTER_KEY=replace-with-at-least-32-random-characters

# Used by docker compose MySQL service.
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_PASSWORD=change-db-password

# Used when running the Go binary directly against MySQL.
DB_DRIVER=mysql
MYSQL_DSN=easypay:change-db-password@tcp(127.0.0.1:3306)/easypay_plus?parseTime=true&charset=utf8mb4&loc=Local&multiStatements=true
AUTO_MIGRATE=true

# Keep this enabled until the real merchant configuration is ready.
EPAY_MOCK=true
EPAY_BASE_URL=https://epay.jylt.cc
EPAY_MCH_ID=
EPAY_SECRET=
EPAY_CALLBACK_SIGN_MODE=auto
